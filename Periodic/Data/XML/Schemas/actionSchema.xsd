      <xs:enumeration value="DummyHover" />
      <xs:enumeration value="DummyKeyPress" />
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="UI">
    <xs:restriction base="xs:string">
      <xs:enumeration value="ExitApplication2" />
      <xs:enumeration value="TestAction" />
