      <xs:enumeration value="AssetRegistries.PrepareDefaultAssets" />
      <xs:enumeration value="AssetRegistries.PrepareAllAssets" />
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="Uncategorized">
    <xs:union memberTypes="actions:Input actions:UI actions:Bootstrap" />
  </xs:simpleType>
</xsd:schema>