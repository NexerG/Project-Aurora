<?xml version="1.0" encoding="utf-8"?>
<xsd:schema xmlns:actions="http://arctisaurora/ActionDependencies" xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified" targetNamespace="http://arctisaurora/ActionDependencies" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <xs:simpleType name="Input">
    <xs:restriction base="xs:string">
      <xs:enumeration value="Write" />
