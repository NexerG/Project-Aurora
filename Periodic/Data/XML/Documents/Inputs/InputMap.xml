<?xml version="1.0" encoding="utf-8" ?>
<KeybindMap xmlns="http://arctisaurora/AuroraInputTypes"
		  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		  xsi:schemaLocation="http://arctisaurora/AuroraInputTypes ../../Schemas/InputTypeSchema.xsd" >
	<Keybind Trigger="Backspace" Action="ExitApplication">
		<Modifier Key="LeftControl" />
		<Press />
	</Keybind>

	<Keybind Trigger="AnySymbol" Action="Write">
		<Repeat Rate="0.1"/>
	</Keybind>
	
</KeybindMap>