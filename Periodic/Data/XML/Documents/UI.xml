<Window xmlns="http://arctisaurora/AuroraUITypes"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://arctisaurora/UI ../Schemas/UITypeSchema.xsd"
        Width="1280" Height="720" ContentScalingMode="Vertical" Fill="true" ColorHex="#1f6331">

	<GridList ColorHex="c2961d">
		<RowDefinition SizeMode="Star"/>
		<RowDefinition SizeMode="Star"/>
		<RowDefinition SizeMode="Star"/>
		<ColumnDefinition SizeMode="Star"/>
		<ColumnDefinition SizeMode="Star"/>
		<ColumnDefinition SizeMode="Star"/>

		<StackPanel ControlColor="gray" Grid.Column="0" Grid.Row="0">
			<Button ControlColor="red" Height="25"/>
			<Button HeightStar="1"/>
			<Button ControlColor="black" Grid.Column="0" Grid.Row="0" HeightStar="2" HorizontalAlignment="Stretch" onClick="ExitApplication2">
				<TextInput FontSize="24" Text="BBBBBBBB"/>
			</Button>
		</StackPanel>
		<Button ControlColor="black" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
		<Button ControlColor="black" Grid.Column="2" Grid.Row="2"/>
	</GridList>
</Window>