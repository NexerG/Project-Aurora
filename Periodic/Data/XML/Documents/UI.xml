<Window xmlns="http://arctisaurora/AuroraUITypes"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://arctisaurora/UI ../Schemas/UITypeSchema.xsd"
        Width="1280" Height="720" ContentScalingMode="Vertical" Fill="true" >

	<StackPanel ColorHex="#121212" Orientation="Vertical">
		<StackPanel.settings Spacing="5" VerticalAlignment="Bottom"/>
		<StackPanel.settings Spacing="5" VerticalAlignment="Top"/>
		<StackPanel.settings Spacing="5" VerticalAlignment="Bottom"/>
		<StackPanel.settings Spacing="5" />

		<Button ControlColor="red" Width="150" Height="150" onClick="TestAction"/>
		<Button ControlColor="green"/>
		<Button ControlColor="green"/>
		<Button ControlColor="green"/>
		<Button ControlColor="blue" StackIndex="1"/>
		<Button ControlColor="black" StackIndex="2"/>
		<Button ControlColor="yellow" StackIndex="3"/>
		<Button ControlColor="cyan" StackIndex="2" Height="150" ScalingMode ="Uniform"/>
		<Button ControlColor="orange" StackIndex="2" Height="50" ScalingMode="Fill"/>
		<ShortText ControlColor="white" Text="BBB&lt;gg&gt;after" />
	</StackPanel>

</Window>